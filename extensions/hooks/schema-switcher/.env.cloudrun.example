# D-1 Phase 3 — Spoke Cloud Run Environment Configuration
# Apply these env vars to the Zakher Spoke Cloud Run service.
# Required for tenant schema isolation and GCS asset partitioning.
#
# Deploy command:
# gcloud run services update directus-zakher \
#   --region=us-central1 \
#   --set-env-vars="STORAGE_LOCATIONS=gcs,STORAGE_GCS_BUCKET=agility-spoke-assets,STORAGE_GCS_ROOT=tenants/zakher/,TENANT_ID=zakher"

STORAGE_LOCATIONS=gcs
STORAGE_GCS_BUCKET=agility-spoke-assets
STORAGE_GCS_ROOT=tenants/zakher/
TENANT_ID=zakher
